# ==========================================
# Ayurveda Chatbot Environment Variables
# ==========================================

# ── Backend Configurations (Place in backend/.env) ──
PORT=8000
NODE_ENV=development
OPENAI_API_KEY=sk-your-openai-api-key-here
CORS_ORIGIN=http://localhost:5000

# Qdrant Vector DB Settings
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=ayurveda_core_data

# Retrieval and Model Settings
CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
TOP_K=5
SIMILARITY_THRESHOLD=0.35

# ── Frontend Configurations (Place in frontend/.env) ──
VITE_API_URL=http://localhost:8000/api/chat
